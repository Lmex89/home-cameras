APP_NAME=Camera Monitor
DEBUG=true
HOST=0.0.0.0
PORT=8000
SNAPSHOT_RETENTION_DAYS=30
SNAPSHOT_ZIP_AFTER_DAYS=7
VIDEO_RETENTION_DAYS=30
DEFAULT_INTERVAL_SECONDS=60

# Annotated Timelapse Settings
TIMELAPSE_HOUR=21
TIMELAPSE_MINUTE=0
TIMELAPSE_CAMERA_ID=6
TIMELAPSE_OBJECT_CLASSES=person,car,motorcycle
TIMELAPSE_FRAME_DURATION=0.55
TIMELAPSE_WORKERS=3

# ML Analysis Settings
ANALYSIS_ENABLED=true
ANALYSIS_INTERVAL_SECONDS=30
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.5
REVIEW_PERSON_AFTER_HOUR=22
REVIEW_PERSON_BEFORE_HOUR=6
REVIEW_MAX_PERSON_COUNT=5

# Telegram Notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# S3-compatible Storage (for videos > 50 MB, e.g. Backblaze B2)
STORAGE_ENABLED=false
STORAGE_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
STORAGE_BUCKET_NAME=your-bucket
STORAGE_ACCESS_KEY=your_key_id
STORAGE_SECRET_KEY=your_application_key
STORAGE_PUBLIC_URL=https://your-bucket.s3.us-east-005.backblazeb2.com
STORAGE_REGION=us-east-005
